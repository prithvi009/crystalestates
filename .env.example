# ============================================
# Crystal Estates — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git.
# ============================================

# ----- Airtable (Lead Capture) -----
# 1. Go to https://airtable.com/create/tokens
# 2. Create a Personal Access Token with scopes: data.records:read, data.records:write
# 3. Add your base to the token's access list
AIRTABLE_PAT=pat_your_token_here
AIRTABLE_BASE_ID=app_your_base_id_here
AIRTABLE_TABLE_NAME=Leads

# ----- Database (Neon PostgreSQL) -----
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ----- Google Analytics + Ads -----
# GA4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Ads ID (e.g., AW-XXXXXXXXXX)
NEXT_PUBLIC_GADS_ID=
# Google Ads Conversion Label (from your conversion action)
NEXT_PUBLIC_GADS_CONVERSION_LABEL=

# ----- Cloudinary (Image CDN) -----
# Sign up at https://cloudinary.com (free: 25GB storage, 25GB bandwidth/mo)
# Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Admin Panel -----
# Password for the /admin property manager page
ADMIN_PASSWORD=crystal2026

# ----- Airtable Table Schema -----
# Create a table called "Leads" with these columns:
#   Name             (Single line text)
#   Phone            (Phone number)
#   Email            (Email)
#   Source           (Single select: contact_form, lead_capture, property_inquiry, exit_intent, investment_report)
#   Property Interest(Single line text)
#   Property Type    (Single select: Plot, Row House, Flat, Commercial, Land, Not Sure)
#   Budget           (Single select: Under 10L, 10-25L, 25-50L, 50L-1Cr, 1Cr+)
#   Location         (Single select: Solapur City, Pune-Solapur Highway, PMRDA Belt, Solapur Outskirts, Other)
#   Subject          (Single line text)
#   Message          (Long text)
#   Created At       (Date time)
#
# ----- Airtable Automations (set up in Airtable UI) -----
# Trigger: "When a record is created in Leads"
# Action 1: Send email to your team (info@crystalestates.in)
# Action 2: (Optional) Send webhook to Interakt/AiSensy for WhatsApp notification
